{
  "name": "warpgate-mcp",
  "version": "0.1.2",
  "description": "Read-only MCP server for discovering Warpgate targets and safe connection guidance.",
  "license": "MIT",
  "author": "n0pashkov",
  "homepage": "https://github.com/n0pashkov/warpgate-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n0pashkov/warpgate-mcp.git"
  },
  "bugs": {
